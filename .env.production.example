NODE_ENV=production
PORT=8000
PRODUCTION_DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require
SECRET_KEY=replace-with-long-random-secret-min-32-chars
JWT_ACCESS_SECRET=optional-fallback-secret
JWT_ACCESS_EXPIRES_IN=15m
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=https://your-frontend-domain.com
